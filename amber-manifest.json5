{
  schemaVersion: "1.0",
  name: "tau2-purple-agent",
  description: "Claude-powered customer service purple agent for tau2-bench",

  program: {
    image: "ghcr.io/keer0205/tau2-purple-agent:latest",
    entrypoint: "uv run python src/server.py --host 0.0.0.0 --port 9009",
    env: {
      ANTHROPIC_API_KEY: "${config.anthropic_api_key}",
    },
    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
